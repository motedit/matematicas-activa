/* materia-local.css — Estilos propios de Álgebra */

/* Color de acento de esta materia */
:root {
    --mat-color: #7c3aed;
}

/* Header con el color de la materia */
.mat-header {
    background: linear-gradient(135deg, #0f172a 0%, #7c3aed44 100%) !important;
}

/* Badge y acentos propios */
.mat-section-title::before {
    color: #7c3aed;
}
